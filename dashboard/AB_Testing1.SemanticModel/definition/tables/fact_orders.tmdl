table fact_orders
	lineageTag: 90a77fc7-3da2-44b9-ac4a-65f32c86f076

	measure Revenue = ```
			SUM(fact_orders[order_value]) 
			```
		formatString: 0
		lineageTag: 8b5b7edd-d5e5-471b-84c3-26b458d8422c

	measure Purchasers = ```
			DISTINCTCOUNT(fact_orders[user_id]) 
			```
		formatString: 0
		lineageTag: bf824e2c-6b18-4e0f-80a1-c7d72ca82816

	measure Conversion_Rate = ```
			([Purchasers]/[Users])*100 
			```
		lineageTag: 2d1ea474-6293-4568-a283-af95e27ac002

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Revenue_per_user = ```
			([Revenue]/[Users]) 
			```
		lineageTag: 1a96efc3-1870-4a25-8930-42afea79f8db

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AOV = ([Revenue]/COUNTROWS(fact_orders))
		lineageTag: 46cd0eaa-9e58-49d6-8640-1a2d6b0a170f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure uplift_perc = VAR TestCR = CALCULATE([Conversion_Rate],fact_experiment_exposure[experiment_group]="Test") VAR ControlCR = CALCULATE([Conversion_Rate],fact_experiment_exposure[experiment_group]="Control") RETURN ((TestCR-ControlCR)*100/(ControlCR))
		lineageTag: b0839369-831f-4376-ba8c-380c6b0c10b0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

