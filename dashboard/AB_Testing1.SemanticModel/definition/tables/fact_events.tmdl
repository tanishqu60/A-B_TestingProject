table fact_events
	lineageTag: 3fb8da53-eae7-4dea-880a-05fce4c3cafd

	measure Page_Views = CALCULATE(COUNTROWS(fact_events),fact_events[event_name]="page_view" )
		formatString: 0
		lineageTag: 687b3aa0-77cd-4513-8a0a-c90971320078

	measure Searches = ```
			CALCULATE(COUNTROWS(fact_events),fact_events[event_name]="search") 
			```
		formatString: 0
		lineageTag: 48e52698-f6b1-4c63-be5f-2a55db7e843d

	measure Product_Views = ```
			CALCULATE(COUNTROWS(fact_events),fact_events[event_name]="view_content") 
			```
		formatString: 0
		lineageTag: 6ae51e98-bcc7-4158-b38c-0c4e36a50e98

	measure Carts = ```
			CALCULATE(COUNTROWS(fact_events),fact_events[event_name]="add_to_cart") 
			```
		formatString: 0
		lineageTag: c2e03c9b-e7ce-4b00-afb7-66a630c1df4f

	measure Purchases = ```
			CALCULATE(COUNTROWS(fact_events),fact_events[event_name]="purchase") 
			```
		formatString: 0
		lineageTag: 2dacfacb-f545-467e-bedd-5057d1ffbcd8

	measure Total_sessions = ```
			DISTINCTCOUNT(fact_events[session_id]) 
			```
		formatString: 0
		lineageTag: 5f4611b0-e374-49be-9ba3-4da42aa90ed7

	measure Returning_users = COUNTROWS(FILTER(ADDCOLUMNS(VALUES(dim_users[user_id]),"SessionCount",CALCULATE(DISTINCTCOUNT(fact_events[session_id]))),[SessionCount]>1))
		formatString: 0
		lineageTag: 992a5392-34db-427c-909e-0c28666975af

	measure Returning_user_perc = ```
			([Returning_users]/[Users])*100 
			```
		lineageTag: edabb563-ecd2-422c-8074-58a1f4feae3e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Sessions_per_user = CALCULATE(DISTINCTCOUNT(fact_events[session_id]))
		formatString: 0
		lineageTag: 36bc02c5-2061-4960-9077-f04568ee05ab

